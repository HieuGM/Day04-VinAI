# Day 04 Lab v2 — Research Agent
# Copy this file to `.env` (same folder) and fill in your keys.
# NEVER commit `.env` — it is gitignored. Keys here are NAMES ONLY (no values).

# --- Model provider (choose ONE; OpenRouter recommended) ---
OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# --- Research / read tools ---
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
RAPIDAPI_KEY=
